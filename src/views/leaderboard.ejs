<!DOCTYPE html>
<html lang="pl">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tablica Wyników - Pszczółki WoF</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"
    integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
  <link rel="stylesheet" href="/assets/css/styles.css">
  <link rel="stylesheet" href="/assets/css/leaderboard_styles.css">
  <!-- Favicon -->
  <link rel="icon" href="/assets/images/wof-internal/wof-logo-favicon.png" type="image/x-icon">
</head>

<body>
  <%- include('./components/header/_header.ejs') %>
    <main class="container mt-4"> <!-- Changed to 'container' for PC, default Bootstrap padding -->
      <!-- Top controls of the page like track dropodwn, select track, virual leadearbaord and filtering-->
      <%- include('components/leaderboard/_top_controls', { trackList: trackList}) %>

      <!-- Advanced Filtering Options (initially hidden) -->
      <%- include('components/leaderboard/_filtering_dropdown') %>

      <!-- Virtual Lap Time Section (initially hidden)-->
      <%- include('components/leaderboard/_virtual_lap_time') %>

      <!-- Leaderboard Table -->
      <%- include('components/leaderboard/_leaderboard_table', { leaderboard: leaderboard }) %>

    </main>
    <%- include('./components/leaderboard/_scripts.ejs') %>
</body>

</html>