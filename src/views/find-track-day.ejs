<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> – Pszczółki WoF</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
  <link rel="stylesheet" href="/assets/css/styles.css">
  <link rel="stylesheet" href="/assets/css/find-track-day.css"> <!-- NEW: Custom CSS for this page -->
</head>
<body>
  <%- include('./components/header/_header.ejs') %>
  <main class="container mt-4">
    <h1 class="mb-4 text-center">Kalendarz Track Day</h1>

    <!-- Track Filter Dropdown -->
    <div class="mb-4">
        <label for="trackFilter" class="form-label visually-hidden">Wybierz tor:</label>
        <select class="form-select" id="trackFilter">
            <option value="">Wszystkie tory</option>
            <!-- Options will be populated by JavaScript -->
        </select>
    </div>

    <div id="eventsContainer" class="row row-cols-1 g-4"> <!-- CORRECTED: Changed to row-cols-1 -->
      <% if (events && events.length > 0) { %>
        <% events.forEach(event => { %>
          <div class="col event-card-col" data-track="<%= event.track %>"> <!-- Added data-track attribute for filtering -->
            <div class="card h-100 shadow-sm event-card">
              <div class="card-body d-flex flex-column">
                <div class="d-flex justify-content-between align-items-start mb-2"> <!-- NEW: Flex container for organizer name and logo -->
                  <h5 class="card-title text-primary mb-0"><%= event.organizer %></h5>
                  <% 
                    const logoFileName = event.organizer.toLowerCase().replace(/\s/g, '_') + '.png';
                    const logoPath = `/images/organizers/${logoFileName}`;
                  %>
                  <img src="<%= logoPath %>" alt="<%= event.organizer %> Logo" class="img-fluid ms-3" style="max-height: 40px;"> <!-- NEW: Organizer Logo -->
                </div>
                <h6 class="card-subtitle mb-2 text-muted"><%= event.date %></h6>
                <p class="card-text"><strong>Nazwa:</strong> <%= event.name %></p>
                <p class="card-text"><strong>Tor:</strong> <%= event.track || 'Brak danych' %></p>
                <div class="mt-auto"> <!-- Push link to bottom -->
                  <a href="<%= event.link %>" target="_blank"
                     class="btn btn-outline-primary w-100 mt-3">Sprawdź dostępne miejsca</a>
                </div>
              </div>
            </div>
          </div>
        <% }); %>
      <% } else { %>
        <div class="col-12" id="noEventsMessage"> <!-- NEW: Added ID for JavaScript access -->
          <div class="alert alert-info text-center" role="alert">
            Brak nadchodzących wydarzeń.
          </div>
        </div>
      <% } %>
    </div>
  </main>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
        crossorigin="anonymous"></script>
  <script>
    // Embed events data directly into the HTML
    window.allEvents = JSON.parse('<%- JSON.stringify(events || []) %>');
  </script>
  <script src="/client_scripts/find-track-day.js"></script>
</body>
</html>