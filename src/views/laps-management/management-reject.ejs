<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <title>Odrzucenie <%= type === 'lap' ? 'Okrążenia' : 'Profilu Zawodnika' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light py-5">
    <div class="container">
        <div class="card shadow-sm mx-auto" style="max-width: 600px;">
            <div class="card-body p-4">
                <h3 class="text-center mb-4">Wybierz powody odrzucenia <%= type === 'lap' ? 'okrążenia' : 'profilu zawodnika' %> ID: <%= id %></h3>
                <form action="<%= postUrl %>" method="POST">
                    <input type="hidden" name="token" value="<%= token %>">
                    
                    <% reasons.forEach(group => { %>
                        <div class="mb-4">
                            <h6 class="text-muted border-bottom pb-2"><%= group.group %></h6>
                            <% group.items.forEach(item => { %>
                                <div class="form-check py-1">
                                    <input class="form-check-input" type="checkbox" name="reason" value="<%= item %>" id="reason_<%= item.replace(/\s/g, '_').replace(/[^\w\s]/gi, '') %>">
                                    <label class="form-check-label" for="reason_<%= item.replace(/\s/g, '_').replace(/[^\w\s]/gi, '') %>">
                                        <%= item %>
                                    </label>
                                </div>
                            <% }) %>
                        </div>
                    <% }) %>

                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn btn-danger btn-lg">Odrzuć i wyślij e-mail</button>
                        <a href="javascript:history.back()" class="btn btn-link text-muted">Anuluj</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</body>
</html>