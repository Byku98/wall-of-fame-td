<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Szczegóły Okrążenia - Pszczółki WoF</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <link rel="stylesheet" href="/styles/styles.css">
    <link rel="stylesheet" href="/styles/lap-details.css">
    <!-- Favicon -->
    <link rel="icon" href="/assets/images/wof-internal/wof-logo-favicon.png" type="image/x-icon">
</head>
<body>

    <%- include("partials/cookie-banner") %>

    <%- include('./components/header/_header.ejs') %>
    <main class="container-fluid mt-4 px-0">
        <div class="row mx-0">
            <div class="col-md-12">
               <%- include('components/lap-details/_rider_header') %>
            </div>
        </div>
        <div class="row mt-4 mx-0">
            <div class="col-md-6" id="lap-details-left">
                <%- include('components/lap-details/_rider_single_lap_details') %>
            </div>
            <div class="col-md-6">
                <%- include('components/lap-details/_rider_track_history') %>
            </div>
        </div>
        <a href="<%= ROUTES.PAGES.LEADERBOARD %>" class="btn btn-primary col-md-12 mb-3 mt-3">Powrót do tablicy wyników</a>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
        crossorigin="anonymous"></script>
        <!-- Include client-side scripts -->
    <script src="/scripts/utils.js" type="module"></script>
    <script src="/client_scripts/lap-details.js" type="module"></script>
</body>
</html>