{
  "name": "pszczolki-wof-terms",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch 'src/**/*.ts' --exec ts-node src/index.ts",
    "build": "rm -rf dist && tsc && npm run copy-assets",
    "copy-assets": "cp -r src/views dist/views && cp -r src/scripts dist/scripts",
    "start": "node dist/index.js",
    "start:prod": "NODE_ENV=production node dist/index.js"
  },
  "dependencies": {
    "bootstrap": "^5.3.8",
    "dotenv": "^17.2.3",
    "ejs": "^3.1.10",
    "express": "^4.18.3",
    "helmet": "^7.1.0",
    "multer": "^2.0.2",
    "mysql2": "^3.9.2",
    "nodemailer": "^7.0.13",
    "python-shell": "^5.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.12.12",
    "@types/nodemailer": "^7.0.9",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
