<div class="container py-5">
    <h1>Dodaj Czas Okrążenia</h1>
    <p>Wypełnij poniższe pola, aby dodać nowy czas okrążenia do bazy danych.</p>

    <form id="addLaptimeForm">

        <!-- Track Selection -->
        <div class="mb-3">
            <label for="trackSelect" class="form-label">Wybierz Tor</label>
            <select class="form-select" id="trackSelect" name="trackName" required>
                <option value="">-- Wybierz tor --</option>
                <% if (typeof trackList !=='undefined' && trackList.length> 0) { %>
                    <% trackList.forEach(track=> { %>
                        <option value="<%= track.track_name %>">
                            <%= track.track_name %>
                        </option>
                        <% }) %>
                            <% } %>
            </select>
            <div class="form-text text-muted">
                <span class="badge bg-danger me-1">Wymagane</span> Wybierz tor, na którym został uzyskany czas.
            </div>
        </div>

        <!-- Organizer Selection -->
        <div class="mb-3">
            <label for="organizer" class="form-label">Organizator</label>
            <select class="form-select" id="organizerList" name="organizer" required disabled>
                <option value="">-- Wybierz organizatora --</option>
                <!-- Options will be populated dynamically by JavaScript -->
            </select>
            <div class="form-text text-muted">
                <span class="badge bg-danger me-1">Wymagane</span> Wybierz organizatora u którego zrobiłeś wynik.
            </div>
        </div>

        <!-- Rider Name -->
        <div class="mb-3">
            <label for="riderName" class="form-label">Imię Zawodnika</label>
            <input type="text" class="form-control" id="riderName" name="riderName" placeholder="Wprowadź imię"
                list="riderSuggestions" required disabled>
            <datalist id="riderSuggestions"></datalist>
            <div class="form-text text-muted">
                <span class="badge bg-danger me-1">Wymagane</span> Aby dodać kolejny wynik wprowadź nazwą istniejącego zawodnika.
                Upewnij się że nazwa jest taka sama jak w istniejącej tabeli. Jeżeli zawodnik jest nowy, zostanie on
                automatycznie utworzony.
            </div>
        </div>

        <!-- Lap Time (Single Text Input) -->
        <div class="mb-3">
            <label for="lapTime" class="form-label">Czas Okrążenia</label>
            <input type="text" class="form-control" id="lapTime" name="lapTime" placeholder="np. 1:05.120, 01:05.12, 58.454"
                pattern="([0-5]?\d:)?([0-5]?\d)\.\d{1,3}" 
                title="Format: MM:SS.mmm lub SS.mmm (np. 1:05.12, 01:05.12, 58.454)" required disabled>
            <div class="form-text text-muted">
                <span class="badge bg-danger me-1">Wymagane</span> Podaj czas okrążenia w formacie minuty:sekundy.milisekundy (np. np. 1:05.12, 01:05.12, 58.454).
            </div>
        </div>

        <!-- Device Selection -->
        <div class="mb-3">
            <label for="device" class="form-label">Urządzenie Pomiarowe</label>
            <select class="form-select" id="deviceSelect" name="device" required disabled>
                <option value="">-- Wybierz urządzenie --</option>
                <% if (typeof devicesList !=='undefined' && devicesList.length> 0) { %>
                    <% devicesList.forEach(device=> { %>
                        <option value="<%= device.device_name %>">
                            <%= device.device_name %>
                        </option>
                        <% }) %>
                            <% } %>
            </select>
            <div class="form-text text-muted">
                <span class="badge bg-danger me-1">Wymagane</span> Wybierz urządzenie, które mierzyło czas.
            </div>
        </div>

        <!-- Device lap record URL (shown when specific devices are selected) -->
        <div class="mb-3" id="deviceRecordedLapContainer" style="display: none;">
            <label for="deviceRecordedLap" class="form-label">Link do zapisu przejazdu z urządzenia</label>
            <input type="url" class="form-control" id="deviceRecordedLap" name="deviceRecordedLap"
                placeholder="https://www.racebox.pro/webapp/..." disabled>
            <div class="form-text text-muted">
                <span class="badge bg-secondary me-1">Opcjonalne</span> Podaj link do zapisu przejazdu z urządzenia.
            </div>
        </div>

        <!-- YouTube lap record -->
        <div class="mb-3">
            <label for="youtubeProof" class="form-label">Link do nagrania przejazdu</label>
            <input type="url" class="form-control" id="youtubeProof" name="youtubeProof"
                placeholder="https://www.youtube.com/watch?v=..." disabled>
            <div class="form-text text-muted">
                <span class="badge bg-secondary me-1">Opcjonalne</span> Podaj link do filmu z Twojego przejazdu.
            </div>
        </div>

        <!-- Date Picker -->
        <div class="mb-3">
            <label for="lapDate" class="form-label">Data Okrążenia</label>
            <input type="date" class="form-control" id="lapDate" name="lapDate" required disabled>
            <div class="form-text text-muted">
                <span class="badge bg-danger me-1">Wymagane</span> Wybierz datę, kiedy okrążenie zostało wykonane.
            </div>
        </div>

        <!-- Motorcycle -->
        <div class="mb-3">
            <label for="motorcycle" class="form-label">Motocykl</label>
            <input type="text" class="form-control" id="motorcycle" name="motorcycle" placeholder="np. Yamaha R6"
                list="motorcycleSuggestions" required disabled>
            <datalist id="motorcycleSuggestions"></datalist>
            <div class="form-text text-muted">
                <span class="badge bg-danger me-1">Wymagane</span> Wprowadź markę i model motocykla.
            </div>
        </div>

        <!-- Tyre Front -->
        <div class="mb-3">
            <label for="tyreFront" class="form-label">Opona (przód)</label>
            <input type="text" class="form-control" id="tyreFront" name="tyreFront"
                placeholder="np. Pirelli Supercorsa SC1" list="tyreFrontSuggestions" disabled>
            <datalist id="tyreFrontSuggestions"></datalist>
            <div class="form-text text-muted">
                <span class="badge bg-secondary me-1">Opcjonalne</span> Podaj markę i model opony przedniej.
            </div>
        </div>

        <!-- Tyre Rear -->
        <div class="mb-3">
            <label for="tyreRear" class="form-label">Opona (tył)</label>
            <input type="text" class="form-control" id="tyreRear" name="tyreRear"
                placeholder="np. Pirelli Supercorsa SC2" list="tyreRearSuggestions" disabled>
            <datalist id="tyreRearSuggestions"></datalist>
            <div class="form-text text-muted">
                <span class="badge bg-secondary me-1">Opcjonalne</span> Podaj markę i model opony tylnej.
            </div>
        </div>

        <!-- Image Upload -->
        <div class="mb-3">
            <label for="proofImage" class="form-label">Zdjęcie laptimera</label>
            <input type="file" class="form-control" id="proofImage" name="proofImage" accept="image/*"
                disabled>
            <div class="form-text text-muted">
                <span class="badge bg-secondary me-1">Opcjonalne</span> Prześlij zdjęcie laptimera jako dowód. Nie jest wymagane jeżeli posiadasz udokumentowany przejazd na platformie RaceBox, RaceChrono, LapTrophy itp.
            </div>
        </div>

        <!-- Captcha Placeholder -->
        <div class="mb-3">
            <label for="captcha" class="form-label">Weryfikacja (Captcha)</label>
            <div id="captchaPlaceholder" class="border p-3 bg-light text-muted">
                <!-- Here you would integrate your actual Captcha solution (e.g., reCAPTCHA) -->
                <p>Miejsce na Captcha (np. reCAPTCHA)</p>
                <input type="text" class="form-control" id="captcha" name="captcha" placeholder="Wprowadź kod z obrazka"
                    required disabled>
            </div>
            <div class="form-text text-muted">
                <i class="fas fa-info-circle me-1"></i> Wprowadź tekst widoczny na obrazku, aby potwierdzić, że nie
                jesteś robotem.
            </div>
        </div>

        <button type="submit" class="btn btn-primary" disabled>Dodaj Czas</button>
    </form>
</div>