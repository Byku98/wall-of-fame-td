
    <!-- Dynamic table -->
    <div class="table-responsive">
      <table class="table table-striped table-bordered">
        <thead class="table-dark">
          <tr>
            <th>#</th>
            <th>Name</th>
            <th>Time</th>
            <th>Date</th>
            <th>Track</th>
          </tr>
        </thead>
        <tbody>
          <% tableData.forEach((row, index) => { %>
            <tr>
              <td><%= index + 1 %></td>
              <td><%= row.name %></td>
              <td><%= row.time %></td>
              <td><%= row.date %></td>
              <td><%= row.track %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>