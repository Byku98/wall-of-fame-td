<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <title>Błąd Operacji</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light d-flex align-items-center vh-100">
    <div class="container text-center">
        <div class="card shadow-sm mx-auto" style="max-width: 500px;">
            <div class="card-body p-5">
                <h1 class="text-danger h3 mb-3">❌ Błąd Operacji</h1>
                <p class="mb-4">Nie udało się przetworzyć Twojego żądania.</p>
                <div class="alert alert-danger text-start small">
                    <strong>Powód:</strong> <%= error %>
                </div>
                <div class="d-flex justify-content-center gap-2 mt-3">
                    <a href="javascript:history.back()" class="btn btn-outline-secondary">Wróć i spróbuj ponownie</a>
                    <a href="/leaderboard" class="btn btn-primary">Przejdź do tabeli wyników</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>