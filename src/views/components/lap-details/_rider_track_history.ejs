<div class="card">
    <div class="card-body">
        <h5 class="card-title mb-3">Historia przejazdów</h5>
        <% if (riderHistory && riderHistory.length > 1) { %>
            <div class="table-responsive">
                <table class="table table-striped table-hover" id="rider-history-table">
                    <thead>
                        <tr>
                            <th>Czas okrążenia</th>
                            <th>Motocykl</th>
                            <th>Data</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% riderHistory.forEach(lap => { %>
                            <tr data-lap-time="<%= lap.lap_time %>" data-rider-name="<%= lap.rider_name %>" data-motorcycle="<%= lap.motorcycle %>" data-lap-date="<%= lap.lap_date %>" data-track-name="<%= riderHistory[0].track_name %>">
                                <td><%= lap.lap_time %></td>
                                <td><%= lap.motorcycle %></td>
                                <td><%= lap.lap_date %></td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <p class="text-muted">Brak dodatkowych przejazdów</p>
        <% } %>
    </div>
</div>