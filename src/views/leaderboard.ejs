<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>
    <%= title %>
  </title>
  <link rel="stylesheet" href="/assets/css/styles.css">
  <link rel="stylesheet" href="/assets/css/leaderboard_styles.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

  <div class="container py-5">

    <!-- Top controls -->
    <div class="d-flex align-items-center gap-3 mb-4">

      <!-- Track dropdown -->
      <select class="form-select w-auto" id="trackSelect">
        <% if (typeof trackList !=='undefined' && trackList.length> 0) { %>
          <% trackList.forEach(track=> { %>
            <option value="<%= track.track_id %>" <%=selectedTrackId===track.track_id ? 'selected' : '' %>>
              <%= track.track_name %>
            </option>
            <% }) %>
              <% } %>
      </select>

      <!-- Filter button (locked for now) -->
      <button class="btn btn-primary" id="filterLeaderboard">Pokaż tor</button>

      <!-- New button for extended filters -->
      <button class="btn btn-secondary" id="toggleFiltersDropdown">Filtry</button>

      <!-- Check it out button (locked for now) -->
      <button class="btn btn-secondary" id="virtualLapTime" disabled>Sprawdź się</button>

    </div>

    <!-- Advanced Filtering Options (initially hidden) -->
    <div id="filtersDropdownContainer" class="mb-4 p-3 border rounded collapse fade-collapse">
      <h5>Zaawansowane Opcje Filtrowania</h5>
      <!-- This is where your new filter inputs will go -->
      <div class="row g-3">
        <div class="col-md-4">
          <label for="riderNameFilter" class="form-label">Imię Zawodnika</label>
          <input type="text" class="form-control" id="riderNameFilter" placeholder="Wpisz imię">
        </div>
        <div class="col-md-4">
          <label for="motorcycleFilter" class="form-label">Motocykl</label>
          <input type="text" class="form-control" id="motorcycleFilter" placeholder="Wpisz model">
        </div>
        <!-- Add more filter options here as needed -->
         <button class="btn btn-primary" id="applyFiltersDropdown">Pokaż</button>
      </div>
    </div>

    <!-- Leaderboard Table -->
    <div class="table-responsive" id="leaderboardTableContainer">
      <table class="table table-striped table-hover">
        <thead>
          <tr>
            <th>#</th>
            <th>Czas</th>
            <th>Rider</th>
            <th>Dokładność</th>
            <th>Motocykl</th>
            <th>Opona (przód)</th>
            <th>Opona (tył)</th>
            <th>Data</th>
          </tr>
        </thead>
        <tbody id="leaderboardTableBody">
          <% // Always render the table with data, even if empty, to show "No laps found" %>
            <% if (leaderboard.length> 0) { %>
              <% leaderboard.forEach((lap, index)=> { %>
                <tr>
                  <td>
                    <%= index + 1 %>
                  </td>
                  <td>
                    <%= lap.lap_time %>
                  </td>
                  <td>
                    <%= lap.rider_name %>
                  </td>
                  <td>
                    <%= lap.validity %>
                  </td>
                  <td>
                    <%= lap.motorcycle %>
                  </td>
                  <td>
                    <%= lap.tyre_front %>
                  </td>
                  <td>
                    <%= lap.tyre_rear %>
                  </td>
                  <td>
                    <%= new Date(lap.lap_date).toLocaleDateString() %>
                  </td>
                </tr>
                <% }) %>
                  <% } else { %>
                    <tr>
                      <td colspan="8" class="text-center">Brak czasów dla wybranego toru.</td>
                    </tr>
                    <% } %>
        </tbody>
      </table>
    </div>

  </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/client_scripts/leaderboard.js"></script> <!-- Link to your new script -->
</body>

</html>