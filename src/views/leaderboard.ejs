<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>
    <%= title %>
  </title>
  <link rel="stylesheet" href="/assets/css/styles.css">
  <link rel="stylesheet" href="/assets/css/leaderboard_styles.css.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

  <div class="container py-5">

    <!-- Top controls -->
    <div class="d-flex align-items-center gap-3 mb-4">

      <!-- Track dropdown -->
      <select class="form-select w-auto" id="trackSelect">
        <!-- The default "Wybierz tor" option is now only selected if no track is pre-selected -->
        <option value="" <%=selectedTrackId===null ? 'selected' : '' %>Wybierz tor</option>
        <% if (typeof trackList !=='undefined' ) { %>
          <% trackList.forEach(track=> { %>
            <option value="<%= track.track_id %>" <%=selectedTrackId===track.track_id ? 'selected' : '' %>>
              <%= track.track_name %>
            </option>
            <% }) %>
              <% } %>
      </select>

      <!-- Filter button (locked for now) -->
      <button class="btn btn-secondary" id="filterLeaderboard">Filtruj</button>

      <!-- Check it out button (locked for now) -->
      <button class="btn btn-primary" disabled>Sprawdź się</button>
    </div>
    <!-- Leaderboard Table -->
    <div class="table-responsive" id="leaderboardTableContainer">
      <table class="table table-striped table-hover">
        <thead>
          <tr>
            <th>#</th>
            <th>Lap Time</th>
            <th>Rider</th>
            <th>Validity</th>
            <th>Motorcycle</th>
            <th>Tyre (Front)</th>
            <th>Tyre (Rear)</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody id="leaderboardTableBody">
          <% // Always render the table with data, even if empty, to show "No laps found" %>
            <% if (leaderboard.length> 0) { %>
              <% leaderboard.forEach((lap, index)=> { %>
                <tr>
                  <td>
                    <%= index + 1 %>
                  </td>
                  <td>
                    <%= lap.lap_time %>
                  </td>
                  <td>
                    <%= lap.rider_name %>
                  </td>
                  <td>
                    <%= lap.validity %>
                  </td>
                  <td>
                    <%= lap.motorcycle %>
                  </td>
                  <td>
                    <%= lap.tyre_front %>
                  </td>
                  <td>
                    <%= lap.tyre_rear %>
                  </td>
                  <td>
                    <%= new Date(lap.lap_date).toLocaleDateString() %>
                  </td>
                </tr>
                <% }) %>
                  <% } else { %>
                    <tr>
                      <td colspan="8" class="text-center">Brak czasów dla wybranego toru.</td>
                    </tr>
                    <% } %>
        </tbody>
      </table>
    </div>

  </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/client_scripts/leaderboard.js"></script> <!-- Link to your new script -->
</body>

</html>