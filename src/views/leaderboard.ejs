<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>
    <%= title %>
  </title>
  <link rel="stylesheet" href="/styles/styles.css">
  <link rel="stylesheet" href="/styles/leaderboard_styles.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

  <!-- Include the new header partial -->
  <%- include('components/header/_header') %>


    <div class="container py-5">

      <!-- Top controls of the page like track dropodwn, select track, virual leadearbaord and filtering-->
      <%- include('components/leaderboard/_top_controls', { trackList: trackList}) %>

      <!-- Advanced Filtering Options (initially hidden) -->
      <%- include('components/leaderboard/_filtering_dropdown') %>

      <!-- Virtual Lap Time Section (initially hidden)-->
      <%- include('components/leaderboard/_virtual_lap_time') %>

      <!-- Leaderboard Table -->
      <%- include('components/leaderboard/_leaderboard_table', { leaderboard: leaderboard }) %>

    </div>

    <!-- Include scripts -->
    <%- include('components/leaderboard/_scripts') %>

</body>

</html>