<div class="table-responsive" id="leaderboardTableContainer">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>#</th>
                <th>Czas</th>
                <th>Zawodnik</th>
                <!-- <th>Doświadczenie</th> -->
                <th>Motocykl</th>
                <th>Opona (przód)</th>
                <th>Opona (tył)</th>
                <th>Data</th>
            </tr>
        </thead>
        <tbody id="leaderboardTableBody">
            <% // Always render the table with data, even if empty, to show "Brak czasów dla wybranego toru." %>
                <% if (leaderboard.length > 0) { %>
                    <% leaderboard.forEach((lap, index)=> { %>
                        <tr class="<%= lap.isVirtual ? 'virtual-lap-row' : '' %>">  <%- /* Add this line */ %>
                            <td>
                                <%= index + 1 %>
                            </td>
                            <td>
                                <%= lap.lap_time %>
                            </td>
                            <td>
                                <% if (lap.isVirtual) { %>
                                    Twój czas
                                <% } else { %>
                                    <%= lap.rider_name %>
                                <% } %>
                            </td>
                            <!-- <td>
                                <% if (!lap.isVirtual) { %>
                                    <%= lap.rider_level %>
                                <% } %>
                            </td> -->
                            <td>
                                <% if (!lap.isVirtual) { %>
                                    <%= lap.motorcycle %>
                                <% } %>
                            </td>
                            <td>
                                <% if (!lap.isVirtual) { %>
                                    <%= lap.tyre_front %>
                                <% } %>
                            </td>
                            <td>
                                <% if (!lap.isVirtual) { %>
                                    <%= lap.tyre_rear %>
                                <% } %>
                            </td>
                            <td>
                                <% if (!lap.isVirtual) { %>
                                    <%= new Date(lap.lap_date).toLocaleDateString() %>
                                <% } %>
                            </td>
                        </tr>
                        <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="8" class="text-center">Brak czasów dla wybranego toru.</td>
                                </tr>
                            <% } %>
        </tbody>
    </table>
</div>