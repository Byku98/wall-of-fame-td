<div id="virtualLapTimeContainer" class="mb-4 p-3 border rounded collapse fade-collapse">
    <h5 class="text-center">Wprowadź swój czas</h5>
    <div class="row g-3 justify-content-center">
        <div class="col-md-6 text-center">
            <label for="virtualLapInput" class="form-label">Zobacz na którym miejscu jesteś</label>
            <input type="text" class="form-control text-center" id="virtualLapInput" 
                placeholder="np. 1:05.120, 58.454 lub 45"
                pattern="([0-5]?\d:)?([0-5]?\d)(\.\d{1,3})?" 
                title="Format: MM:SS.mmm, SS.mmm lub SS (np. 1:05.12, 45)">
            <div class="form-text text-muted mt-2">
                Podaj czas w formacie minuty:sekundy.milisekundy lub same sekundy (np. 1:05.12, 45).
            </div>
        </div>
        <div class="col-12 d-flex justify-content-center">
            <button class="btn btn-primary me-2" id="applyVirtualLaptime" style="width: 120px;">Pokaż</button>
            <button class="btn btn-secondary" id="clearVirtualLaptime" style="width: 120px;">Wyczyść</button>
        </div>
    </div>
</div>