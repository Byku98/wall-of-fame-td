<div class="table-responsive" id="leaderboardTableContainer">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>#</th>
                <th>Czas</th>
                <th>Zawodnik</th>
                <th>Doświadczenie</th>
                <th>Dokładność</th>
                <th>Motocykl</th>
                <th>Opona (przód)</th>
                <th>Opona (tył)</th>
                <th>Data</th>
            </tr>
        </thead>
        <tbody id="leaderboardTableBody">
            <% // Always render the table with data, even if empty, to show "Brak czasów dla wybranego toru." %>
                <% if (leaderboard.length> 0) { %>
                    <% leaderboard.forEach((lap, index)=> { %>
                        <tr>
                            <td>
                                <%= index + 1 %>
                            </td>
                            <td>
                                <%= lap.lap_time %>
                            </td>
                            <td>
                                <%= lap.rider_name %>
                            </td>
                            <td>
                                <%= lap.rider_level %>
                            </td>
                            <td>
                                <%= lap.validity %>
                            </td>
                            <td>
                                <%= lap.motorcycle %>
                            </td>
                            <td>
                                <%= lap.tyre_front %>
                            </td>
                            <td>
                                <%= lap.tyre_rear %>
                            </td>
                            <td>
                                <%= new Date(lap.lap_date).toLocaleDateString() %>
                            </td>
                        </tr>
                        <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="8" class="text-center">Brak czasów dla wybranego toru.</td>
                                </tr>
                                <% } %>
        </tbody>
    </table>
</div>