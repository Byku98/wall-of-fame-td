<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>
    <%= title %>
  </title>
  <link rel="stylesheet" href="/assets/css/styles.css">
  <link rel="stylesheet" href="/assets/css/leaderboard_styles.css.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

  <div class="container py-5">

    <!-- Top controls -->
    <div class="d-flex align-items-center gap-3 mb-4">

      <!-- Track dropdown (to be filled from DB later) -->
      <select class="form-select w-auto" id="trackSelect">
        <option selected disabled>Track to choose from</option>
        <!-- Options will be dynamically added via JS when DB integration is ready -->
      </select>
    </div>

    <div class="d-flex align-items-center gap-3 mb-4">
      <!-- Filter button (locked for now) -->
      <button class="btn btn-secondary" disabled>Filtruj</button>
    </div>
    
    <div class="d-flex align-items-center gap-3 mb-4">
      <!-- Check it out button (locked for now) -->
      <button class="btn btn-primary" disabled>Sprawdź się</button>
    </div>



  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>