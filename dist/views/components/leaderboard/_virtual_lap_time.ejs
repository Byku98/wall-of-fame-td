<div id="virtualLapTimeContainer" class="mb-4 p-3 border rounded collapse fade-collapse">
    <h5 class="text-center">Wprowadź swój czas</h5>
    <div class="row g-3 justify-content-center">
        <div class="col-md-4 text-center">
            <label for="fasterThanMinutes" class="form-label">(MM:SS.mm)</label>
            <div class="input-group">
                <select class="form-select" id="virtualMinutes">
                    <% for (let i=0; i <=3; i++) { %>
                        <option value="<%= String(i).padStart(2, '0') %>">
                            <%= String(i).padStart(2, '0' ) %>
                        </option>
                        <% } %>
                </select>
                <span class="input-group-text">:</span>
                <select class="form-select" id="virtualSeconds">
                    <% for (let i=0; i <=59; i++) { %>
                        <option value="<%= String(i).padStart(2, '0') %>">
                            <%= String(i).padStart(2, '0' ) %>
                        </option>
                        <% } %>
                </select>
                <span class="input-group-text">.</span>
                <select class="form-select" id="virtualMiliSeconds">
                    <% for (let i=0; i <=99; i++) { %>
                        <option value="<%= String(i).padStart(2, '0') %>">
                            <%= String(i).padStart(2, '0' ) %>
                        </option>
                        <% } %>
                </select>
            </div>
        </div>
        <div class="col-12 d-flex justify-content-center">
            <button class="btn btn-primary me-2" id="applyVirtualLaptime" style="width: 120px;">Pokaż</button>
            <button class="btn btn-secondary" id="clearVirtualLaptime" style="width: 120px;">Wyczyść</button>
        </div>
    </div>
</div>